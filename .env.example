# Required for Opus 4.6 and Sonnet 4 AI features
ANTHROPIC_API_KEY=sk-ant-...

# MongoDB connection (must match existing 8D-Report-KI config)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=8d_report_ki

# JWT secret (must match existing auth config in server.py)
SECRET_KEY=your-jwt-secret-key-here

# Optional: SMTP for email notifications (if qm_email_service is used)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=qm@guehring.de
# SMTP_PASS=...

# Document upload directory (default: ./uploads)
UPLOAD_DIR=./uploads
